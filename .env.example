# PostgreSQL Connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=ytproducer
POSTGRES_USER=ytproducer
POSTGRES_PASSWORD=ytproducer

# Application Settings
ASPNETCORE_ENVIRONMENT=Development
USE_MOCK_DATA=false
MOCK_DATA_JSON_PATH=../../../../docs/Playlist/Outputs

# API Client Settings
API_BASE_URL=http://localhost:8080/api

# Logging
LOG_LEVEL=Information

# Playlist Working Directory
YT_PRODUCER_PLAYLIST_WORKING_DIRECTORY=./

# Media Generation (MCP Media)
YT_PRODUCER_MCP_MEDIA_WORKING_DIRECTORY=/Volumes/Data/Devs/Projects/SkydersLab/Dev
YT_PRODUCER_MCP_MEDIA_PROJECT=OnlineTeamTools.MCP.Media/OnlineTeamTools.MCP.Media.csproj
YT_PRODUCER_MEDIA_INPROGRESS_STALE_MINUTES=180
YT_PRODUCER_MEDIA_PARALLELISM=3

# Image Generation (KieAi MCP)
YT_PRODUCER_MCP_KIEAI_WORKING_DIRECTORY=/Volumes/Data/Devs/Projects/SkydersLab/Dev
YT_PRODUCER_MCP_KIEAI_PROJECT=OnlineTeamTools.MCP.KieAi/OnlineTeamTools.MCP.KieAi.csproj
YT_PRODUCER_KIEAI_IMAGE_MODEL=z-image
YT_PRODUCER_KIEAI_IMAGE_ASPECT_RATIO=16:9

# YouTube MCP
YT_PRODUCER_MCP_YOUTUBE_WORKING_DIRECTORY=/Volumes/Data/Devs/Projects/SkydersLab/Dev
YT_PRODUCER_MCP_YOUTUBE_PROJECT=OnlineTeamTools.MCP.YouTube/OnlineTeamTools.MCP.YouTube.csproj
YT_PRODUCER_YOUTUBE_PLAYLIST_PRIVACY=unlisted
YT_PRODUCER_YOUTUBE_VIDEO_PRIVACY=private
