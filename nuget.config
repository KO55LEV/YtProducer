<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="dunnhumby" value="https://artifactory.dunnhumby.com/artifactory/api/nuget/Nuget" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="DotNetEnv" />
      <package pattern="Microsoft.*" />
      <package pattern="Npgsql" />
      <package pattern="Npgsql.*" />
      <package pattern="Swashbuckle.*" />
      <package pattern="System.*" />
    </packageSource>
    <packageSource key="dunnhumby">
      <package pattern="dunnhumby.*" />
      <package pattern="Dunnhumby.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
